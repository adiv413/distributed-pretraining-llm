From f0ca0ece7b47a9383c942b5508c3e8bc2ae79948 Mon Sep 17 00:00:00 2001
From: adiv413 <adivas612@gmail.com>
Date: Sun, 19 Apr 2026 23:14:09 -0400
Subject: [PATCH] Add CSV logging and 1B flavor for experiments

---
 torchtitan/models/llama3/__init__.py |  9 ++++
 torchtitan/train.py                  | 65 ++++++++++++++++++++++++++++
 2 files changed, 74 insertions(+)

diff --git a/torchtitan/models/llama3/__init__.py b/torchtitan/models/llama3/__init__.py
index 75ab234e..9ef71e09 100644
--- a/torchtitan/models/llama3/__init__.py
+++ b/torchtitan/models/llama3/__init__.py
@@ -48,6 +48,15 @@ llama3_args = {
         attn_type="varlen",
         attn_mask_type="block_causal",
     ),
+    "1B": TransformerModelArgs(
+        dim=2048,
+        n_layers=16,
+        n_heads=16,
+        n_kv_heads=8,
+        ffn_dim_multiplier=1.3,
+        multiple_of=1024,
+        rope_theta=500000,
+    ),
     "8B": TransformerModelArgs(
         dim=4096,
         n_layers=32,
diff --git a/torchtitan/train.py b/torchtitan/train.py
index 6cc53ab4..e2619796 100644
--- a/torchtitan/train.py
+++ b/torchtitan/train.py
@@ -654,6 +654,36 @@ class Trainer(torch.distributed.checkpoint.stateful.Stateful):
         self.checkpointer.load(step=job_config.checkpoint.load_step)
         logger.info(f"Training starts at step {self.step + 1}")
 
+        # --- CSV logging setup (experiment instrumentation) ---
+        # Writes one row per step to the file pointed to by $CSV_OUTPUT.
+        # Rank-0 only. No-op if env var unset.
+        csv_writer = None
+        csv_file = None
+        csv_path = os.environ.get("CSV_OUTPUT")
+        if csv_path and torch.distributed.get_rank() == 0:
+            import csv as _csv
+            os.makedirs(os.path.dirname(csv_path) or ".", exist_ok=True)
+            csv_file = open(csv_path, "w", newline="")
+            csv_writer = _csv.writer(csv_file)
+            csv_writer.writerow([
+                "step", "step_time_s", "tokens_this_step", "peak_mem_gb", "loss"
+            ])
+            csv_file.flush()
+
+        # tokens per step is constant: local_batch * seq_len * grad_accum * dp_world
+        if self.parallel_dims.dp_enabled:
+            _batch_mesh = self.parallel_dims.get_mesh("batch")
+            _dp_world = _batch_mesh.size()
+        else:
+            _dp_world = 1
+        _tokens_per_step = (
+            job_config.training.local_batch_size
+            * job_config.training.seq_len
+            * self.gradient_accumulation_steps
+            * _dp_world
+        )
+        # --- end CSV setup ---
+
         with (
             maybe_enable_profiling(
                 job_config.profiling,
@@ -671,12 +701,42 @@ class Trainer(torch.distributed.checkpoint.stateful.Stateful):
             while self.should_continue_training():
                 self.step += 1
                 self.gc_handler.run(self.step)
+
+                # --- per-step timing for CSV ---
+                if torch.cuda.is_available():
+                    torch.cuda.reset_peak_memory_stats()
+                    torch.cuda.synchronize()
+                _step_start = time.perf_counter()
+                # --- end per-step timing prep ---
+
                 try:
                     self.train_step(data_iterator)
                 except DataloaderExhaustedError:
                     logger.warning("Ran out of data; last step was canceled.")
                     break
 
+                # --- per-step CSV row ---
+                if torch.cuda.is_available():
+                    torch.cuda.synchronize()
+                _step_time = time.perf_counter() - _step_start
+                if csv_writer is not None:
+                    _peak_mem_gb = (
+                        torch.cuda.max_memory_allocated() / 1e9
+                        if torch.cuda.is_available() else 0.0
+                    )
+                    # Loss from metrics_processor is only populated on log steps,
+                    # so we just emit NaN for steps where we don't have it.
+                    # This is fine — parse_results.py doesn't use loss.
+                    csv_writer.writerow([
+                        self.step,
+                        f"{_step_time:.6f}",
+                        _tokens_per_step,
+                        f"{_peak_mem_gb:.4f}",
+                        "",  # loss: leave blank; not needed for systems analysis
+                    ])
+                    csv_file.flush()
+                # --- end per-step CSV row ---
+
                 self.checkpointer.save(
                     self.step, last_step=(self.step == job_config.training.steps)
                 )
@@ -709,6 +769,11 @@ class Trainer(torch.distributed.checkpoint.stateful.Stateful):
             time.sleep(2)
             logger.info("Training completed")
 
+        # --- close CSV ---
+        if csv_file is not None:
+            csv_file.close()
+        # --- end close CSV ---
+
     def should_continue_training(self) -> bool:
         return self.step < self.job_config.training.steps
 
-- 
